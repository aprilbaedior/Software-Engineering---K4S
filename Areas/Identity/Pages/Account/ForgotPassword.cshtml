@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password?";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Krumpin 4 Success</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/auth-pages.css" asp-append-version="true" />
</head>
<body>
    <!-- Navbar -->
    <nav class="login-navbar">
        <a href="/" class="brand">K4S</a>
        <a href="/Identity/Account/Login" class="login-link">Sign In</a>
    </nav>

    <!-- Main Content -->
    <main class="login-content container" role="main" style="padding-top: 4rem; max-width: 480px;">
        <div class="text-center mb-4">
            <i class="bi bi-envelope-open" style="font-size: 3rem; color: #4F0C28;" aria-hidden="true"></i>
        </div>
        <h2 class="mb-3">Forgot Password?</h2>

        <form method="post" novalidate>
            <h5 class="mb-3">Enter your email to receive a reset link.</h5>
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="form-group mb-3">
                <label asp-for="Input.Email" class="form-label">Email</label>
                <input asp-for="Input.Email" type="email" class="form-control" autocomplete="email" aria-required="true" placeholder="Enter your email" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <button type="submit" class="btn btn-primary w-100">Send Reset Link</button>
            </div>

            <div class="login-links text-center">
                <a asp-page="./Login">
                    <i class="bi bi-arrow-left me-1" aria-hidden="true"></i> Back to Sign In
                </a>
            </div>
        </form>
    </main>

    <!-- Footer -->
    <footer class="login-footer">
        <div class="footer-content">
            <div class="footer-top">
                <div class="footer-brand">
                    <h5>K4S</h5>
                    <p><strong>Krumpin 4 Success</strong></p>
                    <p>Empowering youth through creative programming, academic support, and career-focused services.</p>
                </div>
                <div class="footer-social">
                    <h6>Connect With Us</h6>
                    <div class="social-icons">
                        <a href="#" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                        <a href="#" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                        <a href="#" aria-label="Twitter"><i class="bi bi-twitter-x"></i></a>
                    </div>
                </div>
            </div>
            <div class="footer-links">
                <ul>
                    <li><a href="#">Meet The Team</a></li>
                    <li><a href="#">About Us</a></li>
                    <li><a href="#">Contact Us</a></li>
                    <li><a href="#">Accessibility</a></li>
                </ul>
            </div>
            <div class="footer-bottom">
                <p>
                    &copy; 2026 Krumpin 4 Success. All rights reserved. |
                    <a href="#">Privacy Policy</a> |
                    <a href="#">Terms of Service</a>
                </p>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>