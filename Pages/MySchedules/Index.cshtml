@page
@model CS395SI_Spring2023_Group1.Pages.MySchedules.IndexModel
@{
    ViewData["Title"] = "My Schedule";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">

<style>
    .page-header {
        background: #f8f9fa;
        border-left: 5px solid #198754;
        padding: 1.25rem 1.5rem;
        border-radius: 8px;
        margin-bottom: 1.5rem;
    }
    .page-header h2 { font-weight: 700; margin: 0; color: #1a1a2e; }
    .page-header p { margin: 0.25rem 0 0; color: #6c757d; font-size: 0.9rem; }
    .stats-card {
        background: white;
        border-radius: 10px;
        padding: 1rem 1.5rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        border-left: 4px solid #198754;
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    .stats-card .icon { font-size: 1.8rem; color: #198754; }
    .stats-card .num { font-size: 1.5rem; font-weight: 700; color: #1a1a2e; }
    .stats-card .label { font-size: 0.8rem; color: #6c757d; text-transform: uppercase; letter-spacing: 0.5px; }
    .table th { background-color: #f8f9fa; font-weight: 600; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px; color: #495057; }
    .table td { vertical-align: middle; }
    .action-buttons .btn { width: 34px; height: 34px; padding: 0; display: inline-flex; align-items: center; justify-content: center; border-radius: 6px; margin: 0 2px; font-size: 0.85rem; }
    .details-btn { background-color: #e8f4fd; color: #0f3460; border: 1px solid #b8d4f0; }
    .details-btn:hover { background-color: #0f3460; color: white; }
    .attendance-btn { background-color: #e8f5e9; color: #2e7d32; border: 1px solid #a5d6a7; }
    .attendance-btn:hover { background-color: #2e7d32; color: white; }
    .delete-btn { background-color: #fdecea; color: #c0392b; border: 1px solid #f5c6cb; }
    .delete-btn:hover { background-color: #c0392b; color: white; }
    .browse-btn { background-color: #198754; color: white; border: none; border-radius: 8px; padding: 0.5rem 1.2rem; font-size: 0.9rem; text-decoration: none; display: inline-flex; align-items: center; gap: 0.4rem; }
    .browse-btn:hover { background-color: #157347; color: white; }
    .empty-state { text-align: center; padding: 3rem; color: #6c757d; }
    .empty-state i { font-size: 3rem; margin-bottom: 1rem; opacity: 0.4; display: block; }
</style>

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2><i class="bi bi-calendar-check me-2 text-success"></i>My Schedule</h2>
        <p>Your enrolled services and sections</p>
    </div>
    <a asp-page="/StudentSchedule/AvailableService" class="browse-btn">
        <i class="fas fa-search"></i> Browse Services
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="stats-card">
            <div class="icon"><i class="fas fa-book-open"></i></div>
            <div>
                <div class="num">@Model.Spring2026_Group1_Schedule.Count</div>
                <div class="label">Enrolled Sections</div>
            </div>
        </div>
    </div>
</div>

@if (!Model.Spring2026_Group1_Schedule.Any())
{
    <div class="card shadow-sm">
        <div class="card-body empty-state">
            <i class="fas fa-calendar-times"></i>
            <h5>No Enrolled Sections</h5>
            <p class="mb-3">You haven't enrolled in any sections yet.</p>
            <a asp-page="/StudentSchedule/AvailableService" class="browse-btn">
                <i class="fas fa-search"></i> Browse Available Services
            </a>
        </div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Service</th>
                            <th>Section</th>
                            <th>Day</th>
                            <th>Start Time</th>
                            <th>End Time</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Spring2026_Group1_Schedule)
                        {
                            <tr>
                                <td><strong>@(item.ServiceName ?? item.ServiceID ?? "—")</strong></td>
                                <td><span class="badge bg-secondary">Section #@item.SectionID</span></td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.WeekDay))
                                    {
                                        foreach (var day in item.WeekDay.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                        {
                                            <span class="badge me-1" style="background-color:#C5D2F8;color:#4F0C28;font-size:0.75rem;">@day.Trim()</span>
                                        }
                                    }
                                    else { <span class="text-muted">—</span> }
                                </td>
                                <td>@(item.StartTime.HasValue ? DateTime.Today.Add(item.StartTime.Value).ToString("hh:mm tt") : "—")</td>
                                <td>@(item.EndTime.HasValue ? DateTime.Today.Add(item.EndTime.Value).ToString("hh:mm tt") : "—")</td>
                                <td>@(item.StartDate.ToString("MM/dd/yyyy") ?? "—")</td> <!-- Assuming StartDate is a DateTime and not nullable, otherwise check for nullability -->
                                <td>@(item.EndDate.ToString("MM/dd/yyyy") ?? "—")</td><!--Also I took off thw question mark hopefully this works ;}-->
                                <td class="text-center action-buttons">
                                    <a asp-page="/MySchedules/Details" asp-route-id="@item.ScheduleID"
                                       class="btn details-btn" title="View Details">
                                        <i class="fas fa-info-circle"></i>
                                    </a>
                                    <a asp-page="/AttendanceForStudent/Index" asp-route-id="@item.ScheduleID"
                                       class="btn attendance-btn" title="View My Attendance">
                                        <i class="fas fa-clipboard-check"></i>
                                    </a>
                                    <a asp-page="/MySchedules/Delete" asp-route-id="@item.ScheduleID"
                                       class="btn delete-btn" title="Drop Section"
                                       onclick="return confirm('Are you sure you want to drop this section?');">
                                        <i class="fas fa-trash-alt"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
