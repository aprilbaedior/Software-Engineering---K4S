@page
@model CS395SI_Spring2023_Group1.Pages.Manager.Certificates.IndexModel
@{
    ViewData["Title"] = "Certificates";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">

<div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="section-title mb-0">
                <i class="bi bi-file-earmark-check me-2"></i> Certificates
            </h1>
            <p class="text-muted mt-1">View all certificates issued to K4S students.</p>
        </div>
        <a asp-page="./Issue" class="btn btn-primary">
            <i class="bi bi-award me-1"></i> Issue New Certificate
        </a>
    </div>

    <!-- Search & Filter -->
    <div class="card mb-4">
        <div class="card-body" style="padding: 1rem 1.5rem;">
            <form method="get" class="d-flex gap-3 align-items-end flex-wrap">
                <div style="flex: 1; min-width: 250px;">
                    <label class="form-label">Search</label>
                    <div class="search-container" style="width: 100%;">
                        <input type="text" name="search" value="@Model.SearchTerm"
                               placeholder="Search by student name or email..." />
                        <button type="submit" class="search-button">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(Model.SearchTerm))
                {
                <div>
                    <a asp-page="./Index" class="btn btn-secondary" style="margin-top: 1.75rem;">
                        <i class="bi bi-x-circle me-1"></i> Clear
                    </a>
                </div>
                }
            </form>
        </div>
    </div>

    <!-- Certificates Table -->
    <div class="card">
        <div class="card-header">
            <i class="bi bi-award me-2"></i> Issued Certificates
            <span class="badge ms-1" style="background-color: #C5D2F8; color: #4F0C28;">@Model.Certificates.Count</span>
        </div>
        <div class="card-body p-0">
            @if (Model.Certificates.Any())
            {
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Student</th>
                            <th>Student Email</th>
                            <th>Service</th>
                            <th>Section</th>
                            <th>Issued By</th>
                            <th>Issued Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cert in Model.Certificates)
                        {
                        <tr>
                            <td>
                                <span class="badge" style="background-color:#4F0C28;color:white;">
                                    #@cert.CertificateID
                                </span>
                            </td>
                            <td><strong>@cert.StudentName</strong></td>
                            <td>@cert.StudentEmail</td>
                            <td>@cert.ServiceName</td>
                            <td>Section #@cert.SectionID</td>
                            <td>@cert.IssuedBy</td>
                            <td>@cert.IssuedDate.ToString("MM/dd/yyyy")</td>
                            <td>
                                <div class="action-buttons">
                                    <a asp-page="./Details" asp-route-id="@cert.CertificateID"
                                       class="btn details-btn" title="View Details">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-page="./Certificate" asp-route-id="@cert.CertificateID"
                                       class="btn details-btn" title="View Certificate" target="_blank"
                                       style="background-color:#C5D2F8; color:#4F0C28;">
                                        <i class="fas fa-scroll"></i>
                                    </a>
                                    <a href="/Managers/Certificates/Certificate?id=@cert.CertificateID&autoprint=true"
                                       class="btn details-btn" title="Print Certificate" target="_blank"
                                       style="background-color:#4F0C28; color:white;">
                                        <i class="fas fa-print"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                        }
                    </tbody>
                </table>
            </div>
            }
            else
            {
            <div class="text-center py-5">
                <i class="bi bi-award" style="font-size: 3rem; color: #ccc;"></i>
                <p class="text-muted mt-3">
                    @if (!string.IsNullOrEmpty(Model.SearchTerm))
                        {
                    <text>No certificates found matching "@Model.SearchTerm".</text>
                        }
                        else
                        {
                    <text>No certificates have been issued yet.</text>
                        }
                </p>
                <a asp-page="./Issue" class="btn btn-primary">
                    <i class="bi bi-award me-1"></i> Issue First Certificate
                </a>
            </div>
            }
        </div>
    </div>
</div>