@page
@model CS395SI_Spring2023_Group1.Pages.Manager.Students.IndexModel
@{
    ViewData["Title"] = "All Students";
}

<div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="section-title mb-0">
                <i class="bi bi-people me-2"></i> All Students
            </h1>
            <p class="text-muted mt-1">View and manage all enrolled students in the K4S program.</p>
        </div>
    </div>

    <!-- Search & Filter Bar -->
    <div class="card mb-4">
        <div class="card-body" style="padding: 1rem 1.5rem;">
            <form method="get" class="d-flex gap-3 align-items-end flex-wrap">
                <div style="flex: 1; min-width: 250px;">
                    <label class="form-label">Search Students</label>
                    <div class="input-group">
                        <input type="text" name="search" value="@Model.SearchTerm"
                               class="form-control" placeholder="Search by name or email..." />
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </div>
                <div style="min-width: 180px;">
                    <label class="form-label">Status Filter</label>
                    <select name="status" class="form-select" onchange="this.form.submit()">
                        <option value="" selected="@(string.IsNullOrEmpty(Model.StatusFilter) ? "selected" : null)">All Statuses</option>
                        <option value="Approved" selected="@(Model.StatusFilter == "Approved" ? "selected" : null)">Approved</option>
                        <option value="Pending" selected="@(Model.StatusFilter == "Pending" ? "selected" : null)">Pending</option>
                        <option value="Denied" selected="@(Model.StatusFilter == "Denied" ? "selected" : null)">Denied</option>
                    </select>
                </div>
                @if (!string.IsNullOrEmpty(Model.SearchTerm) || !string.IsNullOrEmpty(Model.StatusFilter))
                {
                <div>
                    <a asp-page="./Index" class="btn btn-secondary" style="margin-top: 1.75rem;">
                        <i class="bi bi-x-circle me-1"></i> Clear
                    </a>
                </div>
                }
            </form>
        </div>
    </div>

    <!-- Stats Row -->
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card text-center">
                <div class="card-body">
                    <div style="font-size: 2rem; font-weight: 700; color: #4F0C28;">@Model.TotalStudents</div>
                    <div class="text-muted">Total Students</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card text-center">
                <div class="card-body">
                    <div style="font-size: 2rem; font-weight: 700; color: #28a745;">@Model.ApprovedCount</div>
                    <div class="text-muted">Approved</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card text-center">
                <div class="card-body">
                    <div style="font-size: 2rem; font-weight: 700; color: #ffc107;">@Model.PendingCount</div>
                    <div class="text-muted">Pending</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card text-center">
                <div class="card-body">
                    <div style="font-size: 2rem; font-weight: 700; color: #dc3545;">@Model.DeniedCount</div>
                    <div class="text-muted">Denied</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Results Summary -->
    <div class="alert alert-info mb-3">
        <i class="bi bi-info-circle"></i> Showing @Model.Students.Count of @Model.TotalRecords students
    </div>

    <!-- Students Table -->
    <div class="card">
        <div class="card-header">
            <i class="bi bi-table me-2"></i> Student Records
            <span class="badge ms-1" style="background-color: #C5D2F8; color: #4F0C28;">@Model.Students.Count</span>
        </div>
        <div class="card-body p-0">
            @if (Model.Students.Any())
            {
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Date of Birth</th>
                            <th>Application Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var student in Model.Students)
                        {
                        <tr>
                            <td><strong>@student.Name</strong></td>
                            <td>@student.Email</td>
                            <td>@(student.PhoneNum ?? "&mdash;")</td>
                            <td>@(student.DateOfBirth.HasValue ? student.DateOfBirth.Value.ToString("MM/dd/yyyy") : "&mdash;")</td>
                            <td>
                                <span class="status-badge @(student.ApplicationStatus?.ToLower() ?? "unknown")">
                                    @(student.ApplicationStatus ?? "Unknown")
                                </span>
                            </td>
                            <td>
                                <div class="action-buttons">
                                    <a asp-page="/Managers/Students/Profile"
                                       asp-route-id="@student.Email"
                                       class="btn details-btn" title="View Profile">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination Controls -->
            @if (Model.TotalPages > 1)
            {
                <div class="card-footer">
                    <nav aria-label="Student pagination">
                        <ul class="pagination justify-content-center mb-0">
                            <!-- First Page -->
                            <li class="page-item @(Model.PageNumber == 1 ? "disabled" : "")">
                                <a class="page-link" href="?PageNumber=1&search=@Model.SearchTerm&status=@Model.StatusFilter">
                                    <i class="bi bi-chevron-double-left"></i>
                                </a>
                            </li>

                            <!-- Previous Page -->
                            <li class="page-item @(Model.PageNumber == 1 ? "disabled" : "")">
                                <a class="page-link" href="?PageNumber=@(Model.PageNumber - 1)&search=@Model.SearchTerm&status=@Model.StatusFilter">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>

                            <!-- Page Numbers -->
                            @{
                                var startPage = Math.Max(1, Model.PageNumber - 2);
                                var endPage = Math.Min(Model.TotalPages, Model.PageNumber + 2);
                            }

                            @for (int i = startPage; i <= endPage; i++)
                            {
                                <li class="page-item @(Model.PageNumber == i ? "active" : "")">
                                    <a class="page-link" href="?PageNumber=@i&search=@Model.SearchTerm&status=@Model.StatusFilter">
                                        @i
                                    </a>
                                </li>
                            }

                            <!-- Next Page -->
                            <li class="page-item @(Model.PageNumber == Model.TotalPages ? "disabled" : "")">
                                <a class="page-link" href="?PageNumber=@(Model.PageNumber + 1)&search=@Model.SearchTerm&status=@Model.StatusFilter">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>

                            <!-- Last Page -->
                            <li class="page-item @(Model.PageNumber == Model.TotalPages ? "disabled" : "")">
                                <a class="page-link" href="?PageNumber=@Model.TotalPages&search=@Model.SearchTerm&status=@Model.StatusFilter">
                                    <i class="bi bi-chevron-double-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>

                    <div class="text-center text-muted mt-2">
                        <small>Page @Model.PageNumber of @Model.TotalPages</small>
                    </div>
                </div>
            }
            }
            else
            {
            <div class="text-center py-5">
                <i class="bi bi-people" style="font-size: 3rem; color: #ccc;"></i>
                <p class="text-muted mt-3">No students found matching your criteria.</p>
                @if (!string.IsNullOrEmpty(Model.SearchTerm) || !string.IsNullOrEmpty(Model.StatusFilter))
                {
                <a asp-page="./Index" class="btn btn-secondary">Clear Filters</a>
                }
            </div>
            }
        </div>
    </div>
</div>
