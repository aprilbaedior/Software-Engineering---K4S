@page
@model CS395SI_Spring2023_Group1.Pages.Admin.FacultyApplicationsModel
@{
    ViewData["Title"] = "Management Applications";
}

<div class="container-fluid mt-4">
    <div class="row mb-3">
        <div class="col-md-12">
            <h2><i class="bi bi-briefcase"></i> Manager & Administrator Applications</h2>
            <p class="text-muted">Review and approve applications from prospective managers and administrators.</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Tab Navigation -->
    <ul class="nav nav-tabs mb-4">
        <li class="nav-item">
            <a class="nav-link @(Model.ActiveTab == "Pending" ? "active" : "")" 
               asp-page="/Admin/FacultyApplications" asp-route-tab="Pending">
                Pending 
                @if (Model.PendingCount > 0)
                {
                    <span class="badge bg-warning text-dark">@Model.PendingCount</span>
                }
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(Model.ActiveTab == "Approved" ? "active" : "")" 
               asp-page="/Admin/FacultyApplications" asp-route-tab="Approved">
                Approved 
                @if (Model.ApprovedCount > 0)
                {
                    <span class="badge bg-success">@Model.ApprovedCount</span>
                }
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(Model.ActiveTab == "Denied" ? "active" : "")" 
               asp-page="/Admin/FacultyApplications" asp-route-tab="Denied">
                Denied 
                @if (Model.DeniedCount > 0)
                {
                    <span class="badge bg-danger">@Model.DeniedCount</span>
                }
            </a>
        </li>
    </ul>

    @if (Model.Applications.Count == 0)
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No @Model.ActiveTab.ToLower() management applications at this time.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var app in Model.Applications)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">@app.FullName</h5>
                            <small class="text-muted">Applied: @app.ApplicationDate.ToShortDateString()</small>
                        </div>
                        <div class="card-body">
                            <dl class="row mb-0">
                                <dt class="col-sm-5">Email:</dt>
                                <dd class="col-sm-7"><small>@app.Email</small></dd>

                                <dt class="col-sm-5">Phone:</dt>
                                <dd class="col-sm-7"><small>@app.PhoneNumber</small></dd>

                                <dt class="col-sm-5">Position:</dt>
                                <dd class="col-sm-7">
                                    <span class="badge @(app.DesiredPosition == "Manager" ? "bg-warning text-dark" : "bg-danger")">@app.DesiredPosition</span>
                                </dd>

                                @if (!string.IsNullOrEmpty(app.Specialties))
                                {
                                    <dt class="col-sm-5">Expertise:</dt>
                                    <dd class="col-sm-7"><small>@app.Specialties</small></dd>
                                }
                            </dl>

                            @if (!string.IsNullOrEmpty(app.Qualifications))
                            {
                                <hr />
                                <p class="mb-1"><strong>Qualifications:</strong></p>
                                <p class="small text-muted">@(app.Qualifications.Length > 150 ? app.Qualifications.Substring(0, 150) + "..." : app.Qualifications)</p>
                            }

                            @if (!string.IsNullOrEmpty(app.ReviewNotes))
                            {
                                <hr />
                                <p class="mb-1"><strong>Review Notes:</strong></p>
                                <p class="small">@app.ReviewNotes</p>
                                <p class="small text-muted">
                                    Reviewed by @app.ReviewedBy on @app.ReviewDate?.ToShortDateString()
                                </p>
                            }
                        </div>

                        @if (Model.ActiveTab == "Pending")
                        {
                            <div class="card-footer bg-white">
                                <button type="button" class="btn btn-sm btn-success" 
                                        data-bs-toggle="modal" 
                                        data-bs-target="#approveModal-@app.ApplicationID">
                                    <i class="bi bi-check-circle"></i> Approve
                                </button>
                                <button type="button" class="btn btn-sm btn-danger" 
                                        data-bs-toggle="modal" 
                                        data-bs-target="#denyModal-@app.ApplicationID">
                                    <i class="bi bi-x-circle"></i> Deny
                                </button>
                            </div>

                            <!-- Approve Modal -->
                            <div class="modal fade" id="approveModal-@app.ApplicationID" tabindex="-1">
                                <div class="modal-dialog">
                                    <div class="modal-content">
                                        <form method="post" asp-page-handler="Approve">
                                            <input type="hidden" name="id" value="@app.ApplicationID" />
                                            <div class="modal-header bg-success text-white">
                                                <h5 class="modal-title">Approve @app.DesiredPosition Application</h5>
                                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                            </div>
                                            <div class="modal-body">
                                                <p>Are you sure you want to approve <strong>@app.FullName</strong> as a @app.DesiredPosition.ToLower()?</p>
                                                <div class="mb-3">
                                                    <label class="form-label">Notes (Optional)</label>
                                                    <textarea name="notes" class="form-control" rows="3" 
                                                              placeholder="Add any notes or comments..."></textarea>
                                                </div>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                <button type="submit" class="btn btn-success">Approve Application</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>

                            <!-- Deny Modal -->
                            <div class="modal fade" id="denyModal-@app.ApplicationID" tabindex="-1">
                                <div class="modal-dialog">
                                    <div class="modal-content">
                                        <form method="post" asp-page-handler="Deny">
                                            <input type="hidden" name="id" value="@app.ApplicationID" />
                                            <div class="modal-header bg-danger text-white">
                                                <h5 class="modal-title">Deny Application</h5>
                                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                            </div>
                                            <div class="modal-body">
                                                <p>Are you sure you want to deny <strong>@app.FullName</strong>'s application?</p>
                                                <div class="mb-3">
                                                    <label class="form-label">Reason for Denial <span class="text-danger">*</span></label>
                                                    <textarea name="notes" class="form-control" rows="3" required
                                                              placeholder="Please provide a reason for denial..."></textarea>
                                                </div>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                <button type="submit" class="btn btn-danger">Deny Application</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>