@page
@model CS395SI_Spring2023_Group1.Pages.Sections.IndexModel
@{
    ViewData["Title"] = "Manage Sections";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="section-title mb-0">
                <i class="bi bi-calendar3 me-2"></i> Manage Sections
            </h1>
            <p class="text-muted mt-1">@Model.ServiceName</p>
        </div>
        <a asp-page="Create" asp-route-serviceID="@Model.ServiceID" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i> Create New Section
        </a>
    </div>
    <div class="card">
        <div class="card-header">
            <i class="bi bi-list-ul me-2"></i> Sections
            <span class="badge ms-1" style="background-color: #C5D2F8; color: #4F0C28;">@Model.Spring2026_Group1_Sections.Count</span>
        </div>
        <div class="card-body p-0">
            @if (Model.Spring2026_Group1_Sections.Any())
            {
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Section ID</th>
                            <th>Service</th>
                            <th>Day</th>
                            <th>Time</th>
                            <th>Status</th>
                            <th>Capacity</th>
                            <th>Instructor</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Spring2026_Group1_Sections)
                        {
                        <tr>
                            <td><strong>#@item.SectionID</strong></td>
                            <td>@(item.ServiceName ?? "�")</td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.WeekDay))
                                {
                                    foreach (var day in item.WeekDay.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                    {
                                        <span class="badge me-1" style="background-color:#C5D2F8;color:#4F0C28;font-size:0.75rem;">@day.Trim()</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">TBD</span>
                                }
                            </td>
                            <td>
                                @if (item.StartTime.HasValue && item.EndTime.HasValue)
                                {
                                    <span>@DateTime.Today.Add(item.StartTime.Value).ToString("hh:mm tt") - @DateTime.Today.Add(item.EndTime.Value).ToString("hh:mm tt")</span>
                                }
                                else
                                {
                                    <span class="text-muted">Time TBD</span>
                                }
                            </td>
                            <td>
                                <span class="badge @(item.Status == "Active" ? "bg-success" : item.Status == "approved" ? "bg-success" : "bg-secondary")">
                                    @item.Status
                                </span>
                            </td>
                            <td>@(item.Capacity ?? 0)</td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.InstructorName))
                                {
                                    <span>@item.InstructorName</span>
                                }
                                else
                                {
                                    <span class="text-muted">Unassigned</span>
                                }
                            </td>
                            <td class="action-buttons">
                                <a asp-page="./Edit" asp-route-id="@item.SectionID" class="btn edit-btn" title="Edit">
                                    <i class="fas fa-pencil-alt"></i>
                                </a>
                                <a asp-page="./Details" asp-route-id="@item.SectionID" class="btn details-btn" title="View Details">
                                    <i class="fas fa-info-circle"></i>
                                </a>
                                <a asp-page="./Delete" asp-route-id="@item.SectionID" class="btn delete-btn" title="Delete"
                                   onclick="return confirm('Are you sure you want to delete this item?');">
                                    <i class="fas fa-trash-alt"></i>
                                </a>
                                <a asp-page="/AttendanceForAdmin/Index" asp-route-sectionID="@item.SectionID" class="btn attendance-btn" title="View Attendance">
                                    <i class="fas fa-calendar-day"></i>
                                </a>
                            </td>
                        </tr>
                        }
                    </tbody>
                </table>
            </div>
            }
            else
            {
            <div class="text-center py-5">
                <i class="bi bi-calendar-x" style="font-size: 3rem; color: #ccc;"></i>
                <p class="text-muted mt-3">No sections found.</p>
                <a asp-page="Create" asp-route-serviceID="@Model.ServiceID" class="btn btn-primary">
                    <i class="bi bi-plus-circle me-1"></i> Create First Section
                </a>
            </div>
            }
        </div>
    </div>
</div>