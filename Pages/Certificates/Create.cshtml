@page
@model CS395SI_Spring2023_Group1.Pages_Certificates.CreateModel

@{
    ViewData["Title"] = "Issue Certificate";
}

<div class="container mt-4">
    <h1>Issue Service Certificate</h1>
    <p class="text-muted">Issue a certificate to a student for completing a service program</p>

    <hr />

    <div class="row">
        <div class="col-md-8">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <!-- Student Selection -->
                <div class="card mb-3">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="fas fa-user me-2"></i>Student Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="form-group mb-3">
                            <label asp-for="Spring2026_Group1_Certificate.StudentEmail" class="control-label">
                                <span class="text-danger">*</span> Select Student
                            </label>
                            <select asp-for="Spring2026_Group1_Certificate.StudentEmail" 
                                    class="form-select" 
                                    required>
                                <option value="">-- Select Student --</option>
                                @foreach (var student in Model.Students)
                                {
                                    <option value="@student.Email">@student.Name (@student.Email)</option>
                                }
                            </select>
                            <span asp-validation-for="Spring2026_Group1_Certificate.StudentEmail" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <!-- Service & Section Selection (Cascading) -->
                <div class="card mb-3">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0"><i class="fas fa-graduation-cap me-2"></i>Service & Section</h5>
                    </div>
                    <div class="card-body">
                        <!-- Service Dropdown -->
                        <div class="form-group mb-3">
                            <label for="serviceSelect" class="control-label">
                                <span class="text-danger">*</span> Select Service
                            </label>
                            <select id="serviceSelect" 
                                    class="form-select" 
                                    required>
                                <option value="">-- Select Service First --</option>
                                @foreach (var service in Model.Services)
                                {
                                    <option value="@service.ServiceID">@service.ServiceName</option>
                                }
                            </select>
                            <small class="form-text text-muted">
                                Choose the service program first, then select a specific section
                            </small>
                        </div>

                        <!-- Section Dropdown (Cascading - populated via JavaScript) -->
                        <div class="form-group mb-3">
                            <label asp-for="Spring2026_Group1_Certificate.SectionID" class="control-label">
                                <span class="text-danger">*</span> Select Section
                            </label>
                            <select asp-for="Spring2026_Group1_Certificate.SectionID" 
                                    id="sectionSelect"
                                    class="form-select" 
                                    required
                                    disabled>
                                <option value="">-- Select Service First --</option>
                            </select>
                            <span asp-validation-for="Spring2026_Group1_Certificate.SectionID" class="text-danger"></span>
                            <small class="form-text text-muted">
                                Available sections will appear after selecting a service
                            </small>
                        </div>
                    </div>
                </div>

                <!-- Notes -->
                <div class="card mb-3">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0"><i class="fas fa-sticky-note me-2"></i>Additional Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="form-group mb-3">
                            <label asp-for="Spring2026_Group1_Certificate.Notes" class="control-label">Notes (Optional)</label>
                            <textarea asp-for="Spring2026_Group1_Certificate.Notes" 
                                      class="form-control" 
                                      rows="3"
                                      placeholder="Add any special notes about this certificate..."></textarea>
                            <span asp-validation-for="Spring2026_Group1_Certificate.Notes" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="form-group">
                    <button type="submit" class="btn btn-success btn-lg">
                        <i class="fas fa-certificate me-2"></i> Issue Certificate
                    </button>
                    <a asp-page="Index" class="btn btn-secondary btn-lg ms-2">
                        <i class="fas fa-times me-2"></i> Cancel
                    </a>
                </div>
            </form>
        </div>

        <!-- Info Panel -->
        <div class="col-md-4">
            <div class="card border-info">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Information</h5>
                </div>
                <div class="card-body">
                    <h6 class="card-subtitle mb-2 text-muted">Certificate Issuance</h6>
                    <p class="card-text small">
                        This form allows you to issue a certificate to a student who has completed a service program.
                    </p>
                    <hr>
                    <h6 class="card-subtitle mb-2 text-muted">Steps:</h6>
                    <ol class="small">
                        <li>Select the student</li>
                        <li>Choose the service program</li>
                        <li>Select the specific section</li>
                        <li>Add any optional notes</li>
                        <li>Click "Issue Certificate"</li>
                    </ol>
                    <hr>
                    <p class="card-text small mb-0">
                        <strong>Note:</strong> The certificate will be automatically dated with today's date and your name as the issuer.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        $(document).ready(function () {
            // Cascading dropdown: Load sections when service is selected
            $('#serviceSelect').change(function () {
                var serviceId = $(this).val();
                var sectionSelect = $('#sectionSelect');
                
                // Clear and disable section dropdown
                sectionSelect.html('<option value="">-- Loading... --</option>');
                sectionSelect.prop('disabled', true);
                
                if (serviceId) {
                    // Fetch sections for selected service
                    $.ajax({
                        url: '/Certificates/Create?handler=Sections',
                        type: 'GET',
                        data: { serviceId: serviceId },
                        success: function (data) {
                            sectionSelect.html('<option value="">-- Select Section --</option>');
                            
                            if (data && data.length > 0) {
                                $.each(data, function (index, item) {
                                    sectionSelect.append(
                                        $('<option></option>')
                                            .val(item.sectionId)
                                            .text(item.display)
                                    );
                                });
                                sectionSelect.prop('disabled', false);
                            } else {
                                sectionSelect.html('<option value="">-- No sections available --</option>');
                            }
                        },
                        error: function () {
                            sectionSelect.html('<option value="">-- Error loading sections --</option>');
                            alert('Failed to load sections. Please try again.');
                        }
                    });
                } else {
                    sectionSelect.html('<option value="">-- Select Service First --</option>');
                }
            });
        });
    </script>
}

