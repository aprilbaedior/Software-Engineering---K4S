@page
@model CS395SI_Spring2026_Group1.Pages_Instructors.IndexModel
@{
    ViewData["Title"] = "Emergency Contacts";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-telephone-fill me-2"></i> Emergency Contacts</h2>
        <a class="btn btn-secondary" asp-page="/InstructorSections/Index">
            <i class="bi bi-arrow-left"></i> Back to My Sections
        </a>
    </div>

    <!-- Search Bar -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-10">
                    <label class="form-label">Search by Student or Emergency Contact Name</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" 
                               name="SearchTerm" 
                               value="@Model.SearchTerm" 
                               class="form-control" 
                               placeholder="Search by student or contact name...">
                        <input type="hidden" name="SectionID" value="@Model.SectionID" />
                    </div>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search"></i> Search
                    </button>
                </div>
            </form>
            @if (!string.IsNullOrEmpty(Model.SearchTerm))
            {
                <div class="mt-2">
                    <a asp-page="/Instructors/EmergencyContacts" asp-route-sectionID="@Model.SectionID" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-x-circle me-1"></i> Clear Search
                    </a>
                </div>
            }
        </div>
    </div>

    <!-- Results Summary -->
    @if (Model.TotalRecords > 0)
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> Showing @Model.ContactRows.Count of @Model.TotalRecords emergency contacts
        </div>
    }

    <!-- Emergency Contacts Table -->
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">
                <i class="bi bi-list-ul me-2"></i> Emergency Contact Information
                <span class="badge bg-light text-primary ms-2">@Model.ContactRows.Count</span>
            </h5>
        </div>
        <div class="card-body p-0">
            @if (Model.ContactRows == null || !Model.ContactRows.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-telephone-x" style="font-size: 3rem; color: #ccc;"></i>
                    <p class="text-muted mt-3">
                        @if (!string.IsNullOrEmpty(Model.SearchTerm))
                        {
                            <text>No contacts found matching your search.</text>
                        }
                        else
                        {
                            <text>No emergency contacts found.</text>
                        }
                    </p>
                    @if (!string.IsNullOrEmpty(Model.SearchTerm))
                    {
                        <a asp-page="/Instructors/EmergencyContacts" asp-route-sectionID="@Model.SectionID" class="btn btn-secondary">
                            Clear Search
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-bordered mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Student</th>
                                <th>Contact 1</th>
                                <th>Relation</th>
                                <th>Phone</th>
                                <th>Contact 2</th>
                                <th>Relation</th>
                                <th>Phone</th>
                                <th>Contact 3</th>
                                <th>Relation</th>
                                <th>Phone</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model.ContactRows)
                            {
                                <tr>
                                    <td><strong>@r.StudentName</strong></td>

                                    <td>@(r.EmerName ?? "—")</td>
                                    <td>@(r.EmerRelation ?? "—")</td>
                                    <td>@(r.EmerPhone1 ?? "—")</td>

                                    <td>@(r.EmerName2 ?? "—")</td>
                                    <td>@(r.EmerRelation2 ?? "—")</td>
                                    <td>@(r.EmerPhone2 ?? "—")</td>

                                    <td>@(r.EmerName3 ?? "—")</td>
                                    <td>@(r.EmerRelation3 ?? "—")</td>
                                    <td>@(r.EmerPhone3 ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination Controls -->
                @if (Model.TotalPages > 1)
                {
                    <div class="card-footer">
                        <nav aria-label="Emergency contacts pagination">
                            <ul class="pagination justify-content-center mb-0">
                                <!-- First Page -->
                                <li class="page-item @(Model.PageNumber == 1 ? "disabled" : "")">
                                    <a class="page-link" href="?PageNumber=1&SearchTerm=@Model.SearchTerm&SectionID=@Model.SectionID">
                                        <i class="bi bi-chevron-double-left"></i>
                                    </a>
                                </li>

                                <!-- Previous Page -->
                                <li class="page-item @(Model.PageNumber == 1 ? "disabled" : "")">
                                    <a class="page-link" href="?PageNumber=@(Model.PageNumber - 1)&SearchTerm=@Model.SearchTerm&SectionID=@Model.SectionID">
                                        <i class="bi bi-chevron-left"></i>
                                    </a>
                                </li>

                                <!-- Page Numbers -->
                                @{
                                    var startPage = Math.Max(1, Model.PageNumber - 2);
                                    var endPage = Math.Min(Model.TotalPages, Model.PageNumber + 2);
                                }

                                @for (int i = startPage; i <= endPage; i++)
                                {
                                    <li class="page-item @(Model.PageNumber == i ? "active" : "")">
                                        <a class="page-link" href="?PageNumber=@i&SearchTerm=@Model.SearchTerm&SectionID=@Model.SectionID">
                                            @i
                                        </a>
                                    </li>
                                }

                                <!-- Next Page -->
                                <li class="page-item @(Model.PageNumber == Model.TotalPages ? "disabled" : "")">
                                    <a class="page-link" href="?PageNumber=@(Model.PageNumber + 1)&SearchTerm=@Model.SearchTerm&SectionID=@Model.SectionID">
                                        <i class="bi bi-chevron-right"></i>
                                    </a>
                                </li>

                                <!-- Last Page -->
                                <li class="page-item @(Model.PageNumber == Model.TotalPages ? "disabled" : "")">
                                    <a class="page-link" href="?PageNumber=@Model.TotalPages&SearchTerm=@Model.SearchTerm&SectionID=@Model.SectionID">
                                        <i class="bi bi-chevron-double-right"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>

                        <div class="text-center text-muted mt-2">
                            <small>Page @Model.PageNumber of @Model.TotalPages</small>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>