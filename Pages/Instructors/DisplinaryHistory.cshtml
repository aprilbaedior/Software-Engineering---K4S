@page
@model CS395SI_Spring2023_Group1.Pages.Instructors.DisplinaryHistoryModel
@{
    ViewData["Title"] = "Disciplinary History";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-0"><i class="bi bi-journal-text"></i> Disciplinary History</h2>
            @if (!string.IsNullOrEmpty(Model.DisplayName))
            {
                <small class="text-muted">@Model.DisplayName (@Model.DisplayEmail)</small>
            }
        </div>
        <div>
            <button type="button" class="btn btn-outline-secondary" onclick="history.back();">
                <i class="bi bi-arrow-left"></i> Back
            </button>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }
    else if (TempData["InfoMessage"] != null)
    {
        <div class="alert alert-info">@TempData["InfoMessage"]</div>
    }

    @* Section Selector - shown when instructor has multiple sections *@
    @if (Model.AvailableSections.Any())
    {
        <div class="card mb-3">
            <div class="card-body">
                <form method="get" class="row g-3 align-items-end">
                    <div class="col-md-8">
                        <label for="sectionSelect" class="form-label">
                            <i class="bi bi-funnel"></i> Select Section
                        </label>
                        <select id="sectionSelect" name="SectionID" class="form-select" onchange="this.form.submit()">
                            @if (!Model.SectionID.HasValue)
                            {
                                <option value="" selected>-- Choose a section --</option>
                            }
                            @foreach (var item in Model.AvailableSections)
                            {
                                <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-search"></i> Load Section
                        </button>
                    </div>
                </form>
            </div>
        </div>
    }

    @* Roster view when SectionID is provided *@
    @if (Model.StudentsInSection != null && Model.StudentsInSection.Any())
    {
        <div class="card mb-3">
            <div class="card-header">
                <i class="bi bi-people me-2"></i> Students in Section @Model.SectionID
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Student Name</th>
                                <th>Email</th>
                                <th>Strikes</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in Model.StudentsInSection)
                            {
                                var isSelected = string.Equals(s.Email, Model.StudentEmail, StringComparison.OrdinalIgnoreCase);
                                <tr class="@(isSelected ? "table-primary" : "")">
                                    <td>@s.Name</td>
                                    <td>@s.Email</td>
                                    <td>
                                        @if (s.StrikeCount > 0)
                                        {
                                            <span class="badge bg-danger">@s.StrikeCount</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">0</span>
                                        }
                                    </td>
                                    <td>
                                        <a asp-page="/Sections/History"
                                           asp-route-StudentEmail="@s.Email"
                                           asp-route-SectionID="@Model.SectionID"
                                           class="btn btn-sm btn-info">
                                            View Records
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else if (Model.SectionID.HasValue)
    {
        <div class="card mb-3">
            <div class="card-body">
                <p class="mb-0">No students enrolled in this section.</p>
            </div>
        </div>
    }

    @* When a single student is requested, the Records UI can remain here if you want — otherwise navigation goes to Sections/History *@
</div>