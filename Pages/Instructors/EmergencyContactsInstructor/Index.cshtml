@page
@model CS395SI_Spring2023_Group1.Pages.Instructors.EmergencyContacts.IndexModel
@{
    ViewData["Title"] = "My Emergency Contacts for My Sections";
}
<h1>Emergency Contacts</h1>

@if (Model.AssignedSections == null || !Model.AssignedSections.Any())
{
    <p>You have no assigned sections.</p>
}
else
{
    <form method="get" class="form-inline mb-3">
        <div class="form-group me-2">
            <label for="sectionSelect" class="me-2">Section:</label>
            <select id="sectionSelect" name="SectionId" class="form-select" onchange="this.form.submit()">
                <option value="">All my sections</option>
                @foreach (var s in Model.AssignedSections)
                {
                    <option value="@s.SectionID" selected="@(Model.SectionId == s.SectionID)">
                        @s.ServiceName - @s.SectionID
                    </option>
                }
            </select>
        </div>

        <div class="form-group me-2">
            <input type="text" name="SearchTerm" value="@Model.SearchTerm" placeholder="Search name, email, phone" class="form-control" />
        </div>

        <div class="form-group">
            <button type="submit" class="btn btn-primary">Search</button>
        </div>
    </form>

    @if (Model.StudentContacts == null || !Model.StudentContacts.Any())
    {
        <p>No students found for the selected section(s).</p>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Student</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Address</th>
                    <th>Emergency Contacts</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model.StudentContacts)
                {
                    <tr>
                        <td>@s.StudentName</td>
                        <td>@s.StudentEmail</td>
                        <td>@s.StudentPhone</td>
                        <td>@s.StudentAddress</td>
                        <td>
                            @if (s.EmergencyContacts != null && s.EmergencyContacts.Any())
                            {
                                <ul class="list-unstyled mb-0">
                                    @foreach (var ec in s.EmergencyContacts)
                                    {
                                        <li><strong>@ec.Priority</strong>: @ec.Name (@ec.Relationship) - @ec.PhoneNumber</li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <span>No emergency contacts</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}