@page
@model CS395SI_Spring2023_Group1.Pages.ServicesForAdmin.DetailsModel
@{
    ViewData["Title"] = "Service Details";
}

<div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="section-title mb-0">
                <i class="bi bi-briefcase me-2"></i> @(Model.Spring2023_Group1_Services.ServiceName ?? "Service Details")
            </h1>
            <p class="text-muted mt-1">Service ID: <strong>@Model.Spring2023_Group1_Services.ServiceID</strong></p>
        </div>
        <div class="d-flex gap-2">
            <a asp-page="./Edit" asp-route-id="@Model.Spring2023_Group1_Services.ServiceID" class="btn btn-primary">
                <i class="bi bi-pencil me-1"></i> Edit
            </a>
            <a asp-page="./Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left me-1"></i> Back to Services
            </a>
        </div>
    </div>

    <!-- Service Info Card -->
    <div class="card mb-4">
        <div class="card-header">
            <i class="bi bi-info-circle me-2"></i> Service Information
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Service Name</dt>
                <dd class="col-sm-9">@(Model.Spring2023_Group1_Services.ServiceName ?? "—")</dd>

                <dt class="col-sm-3">Service ID</dt>
                <dd class="col-sm-9">
                    <span class="badge" style="background-color:#4F0C28;color:white;">
                        @Model.Spring2023_Group1_Services.ServiceID
                    </span>
                </dd>

                <dt class="col-sm-3">Frequency</dt>
                <dd class="col-sm-9">@(Model.Spring2023_Group1_Services.ServiceFrequency ?? "—")</dd>

                <dt class="col-sm-3">Number of Hours</dt>
                <dd class="col-sm-9">@Model.Spring2023_Group1_Services.ServiceHours hrs</dd>

                <dt class="col-sm-3">Description</dt>
                <dd class="col-sm-9">@(Model.Spring2023_Group1_Services.ServiceDescription ?? "—")</dd>
            </dl>
        </div>
    </div>

    <!-- Sections Card -->
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-calendar3 me-2"></i> Available Sections</span>
            <div>
                <span class="badge ms-1" style="background-color: #C5D2F8; color: #4F0C28;">@Model.Sections.Count</span>
                <a asp-page="/Sections/Create" asp-route-serviceID="@Model.Spring2023_Group1_Services.ServiceID"
                   class="btn btn-sm btn-primary ms-2">
                    <i class="bi bi-plus-circle me-1"></i> Add Section
                </a>
            </div>
        </div>
        <div class="card-body p-0">
            @if (Model.Sections.Any())
            {
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Section ID</th>
                            <th>Day</th>
                            <th>Time</th>
                            <th>Dates</th>
                            <th>Capacity</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sec in Model.Sections)
                        {
                        <tr>
                            <td><strong>#@sec.SectionID</strong></td>
                            <td>
                                @if (!string.IsNullOrEmpty(sec.WeekDay))
                                {
                                    foreach (var day in sec.WeekDay.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                    {
                                        <span class="badge me-1" style="background-color:#C5D2F8;color:#4F0C28;font-size:0.75rem;">@day.Trim()</span>
                                    }
                                }
                                else { <span class="text-muted">—</span> }
                            </td>
                            <td>
                                @if (sec.StartTime.HasValue && sec.EndTime.HasValue)
                                {
                                    <span>@DateTime.Today.Add(sec.StartTime.Value).ToString("hh:mm tt") - @DateTime.Today.Add(sec.EndTime.Value).ToString("hh:mm tt")</span>
                                }
                                else
                                {
                                    <span class="text-muted">TBD</span>
                                }
                            </td>
                            <td>
                                @if (sec.StartDate.HasValue && sec.EndDate.HasValue)
                                {
                                    <span>@sec.StartDate.Value.ToString("MM/dd/yyyy") &ndash; @sec.EndDate.Value.ToString("MM/dd/yyyy")</span>
                                }
                                else
                                {
                                    <span class="text-muted">TBD</span>
                                }
                            </td>
                            <td>@sec.Capacity</td>
                            <td>
                                <span class="badge @(sec.Status == "Active" ? "bg-success" : sec.Status == "Open" ? "bg-primary" : "bg-secondary")">
                                    @(sec.Status ?? "—")
                                </span>
                            </td>
                            <td class="action-buttons">
                                <a asp-page="/Sections/Edit" asp-route-id="@sec.SectionID" class="btn edit-btn" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-page="/Sections/Details" asp-route-id="@sec.SectionID" class="btn details-btn" title="View Details">
                                    <i class="bi bi-info-circle"></i>
                                </a>
                            </td>
                        </tr>
                        }
                    </tbody>
                </table>
            </div>
            }
            else
            {
            <div class="text-center py-5">
                <i class="bi bi-calendar-x" style="font-size: 3rem; color: #ccc;"></i>
                <p class="text-muted mt-3">No sections have been created for this service yet.</p>
                <a asp-page="/Sections/Create" asp-route-serviceID="@Model.Spring2023_Group1_Services.ServiceID"
                   class="btn btn-primary">
                    <i class="bi bi-plus-circle me-1"></i> Create First Section
                </a>
            </div>
            }
        </div>
    </div>
</div>
