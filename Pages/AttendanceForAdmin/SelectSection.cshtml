@page
@model CS395SI_Spring2023_Group1.Pages.AttendanceForAdmin.SelectSectionModel
@{
    ViewData["Title"] = "Select Section - Take Attendance";
}

<div class="container mt-4">
    <h2><i class="bi bi-check2-square"></i> Take Attendance</h2>
    <p class="text-muted">Select a section to take attendance for:</p>

    @if (Model.AssignedSections == null || !Model.AssignedSections.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> You currently have no sections assigned.
        </div>
        <a asp-page="/InstructorSections/Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to My Sections
        </a>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model.AssignedSections)
            {
                <div class="col-md-6 col-lg-4 mb-3">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">@item.ServiceName</h5>
                            <p class="card-text">
                                <strong>Section ID:</strong> @item.SectionID<br />
                                <strong>Day:</strong> @item.WeekDay<br />
                                <strong>Time:</strong> 
                                @if (item.StartTime.HasValue && item.EndTime.HasValue)
                                {
                                    <text>@DateTime.Today.Add(item.StartTime.Value).ToString("hh:mm tt") - @DateTime.Today.Add(item.EndTime.Value).ToString("hh:mm tt")</text>
                                }
                                <br />
                                <strong>Capacity:</strong> @item.Capacity
                            </p>
                            @if (item.Status == "Active")
                            {
                                <span class="badge bg-success mb-2">@item.Status</span>
                            }
                            else if (item.Status == "Open")
                            {
                                <span class="badge bg-info mb-2">@item.Status</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary mb-2">@item.Status</span>
                            }
                        </div>
                        <div class="card-footer">
                            <a asp-page="/AttendanceForAdmin/Index" 
                               asp-route-sectionID="@item.SectionID" 
                               class="btn btn-primary w-100">
                                <i class="bi bi-check2-square"></i> Take Attendance
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>