@page
@model CS395SI_Spring2023_Group1.Pages_Students.IndexModel

@{
    ViewData["Title"] = "Students";
}

<div class="container mt-4">
    <h1>Students</h1>

    <!-- Search and Filter Panel -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Search & Filter</h5>
        </div>
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-5">
                    <label class="form-label">Search by Name or Email</label>
                    <input type="text" name="searchTerm" class="form-control" placeholder="Enter name or email" value="@Model.SearchTerm">
                </div>
                <div class="col-md-3">
                    <label class="form-label">Filter by Status</label>
                    <select name="statusFilter" class="form-select">
                        <option value="">All Students</option>
                        <option value="Active" selected="@(Model.StatusFilter == "Active")">Active</option>
                        <option value="Inactive" selected="@(Model.StatusFilter == "Inactive")">Inactive</option>
                    </select>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-search me-2"></i> Search
                    </button>
                </div>
            </form>
        </div>
    </div>

    <p>
        <a asp-page="Create" class="btn btn-success">
            <i class="fas fa-plus me-2"></i> Create New Student
        </a>
    </p>

    <!-- Results Summary -->
    <div class="alert alert-info">
        Showing @Model.Spring2026_Group1_Students.Count of @Model.TotalRecords students
    </div>

    @if (Model.Spring2026_Group1_Students.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Enrollment Date</th>
                        <th>Status</th>
                        <th>End Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Spring2026_Group1_Students)
                    {
                        <tr>
                            <td>
                                @item.Name
                            </td>
                            <td>
                                @item.Email
                            </td>
                            <td>
                                @if (item.EnrollmentDate.HasValue)
                                {
                                    @item.EnrollmentDate.Value.ToShortDateString()
                                }
                                else
                                {
                                    <span class="text-muted">N/A</span>
                                }
                            </td>
                            <td>
                                @if (item.IsActive == true)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>
                                @if (item.EndDate.HasValue)
                                {
                                    @item.EndDate.Value.ToShortDateString()
                                }
                                else
                                {
                                    <span class="text-muted">N/A</span>
                                }
                            </td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-page="./Edit" asp-route-id="@item.StudentID" class="btn btn-sm btn-warning">Edit</a>
                                    <a asp-page="./Details" asp-route-id="@item.StudentID" class="btn btn-sm btn-info">Details</a>
                                    <a asp-page="./Delete" asp-route-id="@item.StudentID" class="btn btn-sm btn-danger">Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination Controls -->
        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Student pagination" class="mt-3">
                <ul class="pagination justify-content-center">
                    <!-- First Page -->
                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" href="?pageNumber=1&searchTerm=@Model.SearchTerm&statusFilter=@Model.StatusFilter">
                            <i class="fas fa-angle-double-left"></i>
                        </a>
                    </li>

                    <!-- Previous Page -->
                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" href="?pageNumber=@(Model.CurrentPage - 1)&searchTerm=@Model.SearchTerm&statusFilter=@Model.StatusFilter">
                            <i class="fas fa-angle-left"></i>
                        </a>
                    </li>

                    <!-- Page Numbers -->
                    @{
                        var startPage = Math.Max(1, Model.CurrentPage - 2);
                        var endPage = Math.Min(Model.TotalPages, Model.CurrentPage + 2);
                    }

                    @for (int i = startPage; i <= endPage; i++)
                    {
                        <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                            <a class="page-link" href="?pageNumber=@i&searchTerm=@Model.SearchTerm&statusFilter=@Model.StatusFilter">
                                @i
                            </a>
                        </li>
                    }

                    <!-- Next Page -->
                    <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" href="?pageNumber=@(Model.CurrentPage + 1)&searchTerm=@Model.SearchTerm&statusFilter=@Model.StatusFilter">
                            <i class="fas fa-angle-right"></i>
                        </a>
                    </li>

                    <!-- Last Page -->
                    <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" href="?pageNumber=@Model.TotalPages&searchTerm=@Model.SearchTerm&statusFilter=@Model.StatusFilter">
                            <i class="fas fa-angle-double-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>

            <div class="text-center text-muted">
                <small>Page @Model.CurrentPage of @Model.TotalPages</small>
            </div>
        }
    }
    else
    {
        <div class="alert alert-warning">
            <i class="fas fa-info-circle me-2"></i>
            No students found matching your criteria.
        </div>
    }
</div>
